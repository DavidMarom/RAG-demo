# ─────────────────────────────────────────────────────────────────
# DocuChat — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────

# ── OpenAI ──────────────────────────────────────────────────────
# Your OpenAI API key. Used for chat completions (GPT-4o) and embeddings.
OPENAI_API_KEY=sk-...

# ── Pinecone ─────────────────────────────────────────────────────
# API key from console.pinecone.io → API Keys
PINECONE_API_KEY=pcsk-...

# Name of the Pinecone index to use (created via scripts/create-index.ts)
PINECONE_INDEX_NAME=docuchat

# Pinecone host URL (optional, used by older Pinecone SDK versions)
# PINECONE_HOST=https://docuchat-xxx.svc.us-east1-gcp.pinecone.io

# ── Cohere (optional — enables higher-quality reranking) ─────────
# If not set, the system falls back to BM25 reranking.
# Get your key at dashboard.cohere.com
COHERE_API_KEY=

# ── Upstash Redis ────────────────────────────────────────────────
# REST URL for your Upstash Redis database. Used for rate limiting AND retrieval caching.
UPSTASH_REDIS_REST_URL=https://...upstash.io

# REST token for your Upstash Redis database.
UPSTASH_REDIS_REST_TOKEN=...

# ── Langfuse (optional — enables LLM observability + tracing) ───
# Public key from langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...

# Secret key from langfuse.com → Settings → API Keys
LANGFUSE_SECRET_KEY=sk-lf-...

# Langfuse host (use cloud or self-hosted URL)
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ── Application ──────────────────────────────────────────────────
# Public base URL used by the front-end (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bearer token that protects the /api/ingest and /api/search endpoints.
# Generate a strong random string: openssl rand -hex 32
INGESTION_SECRET=your-very-long-random-secret-token-here
